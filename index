// Componente de Tarjeta con efecto Flip adaptado a Touch
const FlipCard = ({ icon, label, text, summary }) => {
  const [isFlipped, setIsFlipped] = useState(false);

  return (
    <div 
      className="relative h-72 w-full perspective-1000 cursor-pointer mb-4"
      onClick={() => setIsFlipped(!isFlipped)}
    >
      <div className={`relative w-full h-full transition-all duration-500 preserve-3d ${isFlipped ? 'rotate-y-180' : ''}`}>
        
        {/* Cara Frontal */}
        <div className="absolute inset-0 backface-hidden p-6 rounded-2xl bg-white border border-slate-200 shadow-sm flex flex-col active:bg-emerald-50">
          <div className="mb-4 text-emerald-600">{icon}</div>
          <h3 className="text-lg font-bold mb-2 text-slate-800">{label}</h3>
          <p className="text-slate-600 text-sm leading-relaxed">{text}</p>
          <div className="mt-auto flex items-center gap-2 text-[10px] font-bold text-emerald-600 uppercase tracking-widest">
            <Info className="w-3 h-3" /> Toca para ver resumen
          </div>
        </div>

        {/* Cara Trasera */}
        <div className="absolute inset-0 backface-hidden rotate-y-180 p-6 rounded-2xl bg-emerald-700 text-white shadow-lg flex flex-col justify-center items-center text-center">
          <h3 className="text-sm font-bold mb-3 border-b border-emerald-500 pb-2 w-full uppercase tracking-widest">Estrategia</h3>
          <p className="text-emerald-50 text-sm font-medium leading-relaxed">
            {summary}
          </p>
          <div className="mt-4 text-[10px] font-bold uppercase tracking-widest opacity-60">
            Toca para volver
          </div>
        </div>

      </div>
    </div>
  );
};

